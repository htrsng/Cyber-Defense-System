const ActivityLog = require('../models/ActivityLog');
const SecurityEvent = require('../models/SecurityEvent');
const redis = require('../config/redis');
const { calculateRiskScore } = require('../services/riskScorer');

const delay = ms => new Promise(res => setTimeout(res, ms));

async function bruteForce(req, res, io) {
    try {
        const attempts = Math.max(5, Math.min(50, Number(req.body.attempts) || 0));
        const delayMs = Math.max(50, Math.min(1000, Number(req.body.delayMs) || 0));
        const attackerIp = '10.0.0.99';
        const socket = req.app.get('io');

        for (let i = 1; i <= attempts; i += 1) {
            await ActivityLog.create({
                eventType: 'ATTACK_SIM_BRUTE_FORCE',
                ipAddress: attackerIp,
                severity: 'high',
                metadata: {
                    attempt: i,
                    password: `fakepass${i}`,
                },
            });

            if (i % 5 === 0) {
                await redis.incrby(`failed_login:${attackerIp}`, 5);
                await redis.expire(`failed_login:${attackerIp}`, 600);
            }

            if (i < attempts) {
                await delay(delayMs);
            }
        }

        const risk = await calculateRiskScore(attackerIp);
        const finalRiskScore = risk.score;
        const level = risk.level;
        const blocked = finalRiskScore >= 60;

        if (blocked) {
            await redis.set(`blocked_ip:${attackerIp}`, '1', 'EX', 300);
        }

        socket?.emit('security_alert', {
            type: 'BRUTE_FORCE_DETECTED',
            ipAddress: attackerIp,
            severity: level,
            riskScore: finalRiskScore,
            description: `Brute Force: ${attempts} login attempts detected and blocked`,
            timestamp: new Date(),
        });

        return res.json({
            attempts,
            finalRiskScore,
            level,
            blocked,
            reasons: risk.reasons,
        });
    } catch (error) {
        console.error('Brute force simulation error:', error);
        return res.status(500).json({ error: 'Failed to run brute force simulation' });
    }
}

async function sqli(req, res, io) {
    try {
        const axios = require('axios');
        const attackerIp = '10.0.0.88';
        const payloads = [
            "' OR 1=1 --",
            "' UNION SELECT * FROM users --",
            "'; DROP TABLE logs; --",
            "admin'--",
            "' OR 'x'='x",
        ];

        let successfulBypass = false;
        const testResults = [];

        // Test each payload against the login endpoint
        for (const payload of payloads) {
            try {
                const response = await axios.post('http://localhost:5000/api/auth/login', {
                    email: payload,
                    password: payload,
                }, { validateStatus: () => true });

                const isBlocked = response.status === 401 || response.status === 400;
                
                await ActivityLog.create({
                    eventType: 'ATTACK_SIM_SQLI',
                    ipAddress: attackerIp,
                    severity: 'high',
                    metadata: {
                        payload,
                        endpoint: '/api/auth/login',
                        method: 'POST',
                        statusCode: response.status,
                        blocked: isBlocked,
                        successfulBypass: !isBlocked,
                    },
                });

                testResults.push({
                    payload,
                    statusCode: response.status,
                    blocked: isBlocked,
                });

                if (!isBlocked && response.status === 200) {
                    successfulBypass = true;
                }
            } catch (error) {
                // Request error - treat as blocked
                await ActivityLog.create({
                    eventType: 'ATTACK_SIM_SQLI',
                    ipAddress: attackerIp,
                    severity: 'high',
                    metadata: {
                        payload,
                        endpoint: '/api/auth/login',
                        blocked: true,
                        error: error.message,
                    },
                });
                testResults.push({
                    payload,
                    error: error.message,
                    blocked: true,
                });
            }

            await delay(200);
        }

        const result = await calculateRiskScore(attackerIp);
        const socket = req.app.get('io');

        // Only emit alert if there's a potential successful bypass
        if (successfulBypass) {
            socket?.emit('security_alert', {
                type: 'SQLI_DETECTED',
                ipAddress: attackerIp,
                severity: 'critical',
                riskScore: Math.min(100, result.score + 20),
                description: `⚠️ SQL Injection: Successful bypass detected! Authentication bypassed with malicious payload`,
                timestamp: new Date(),
            });
        } else {
            // All payloads were blocked
            socket?.emit('security_alert', {
                type: 'SQLI_DETECTED',
                ipAddress: attackerIp,
                severity: 'high',
                riskScore: result.score,
                description: `SQL Injection: ${payloads.length} malicious payloads detected and blocked by system protection`,
                timestamp: new Date(),
            });
        }

        // Emit detailed activity logs for each test
        for (const test of testResults) {
            socket?.emit('activity_log', {
                eventType: 'ATTACK_SIM_SQLI',
                ipAddress: attackerIp,
                severity: test.blocked ? 'high' : 'critical',
                riskScore: result.score,
                endpoint: '/api/auth/login',
                metadata: test,
                timestamp: new Date(),
            });
            await delay(200);
        }

        return res.json({
            payloadsTested: payloads.length,
            successfulBypass,
            testResults,
            riskScore: result.score,
            level: result.level,
            payloads,
        });
    } catch (error) {
        console.error('SQLi simulation error:', error);
        return res.status(500).json({ error: 'Failed to run SQLi simulation' });
    }
}

async function honeypot(req, res, io) {
    try {
        const attackerIp = '10.0.0.77';
        const honeypotPaths = ['/.env', '/admin/secret', '/wp-admin', '/admin/backup', '/phpmyadmin'];
        const socket = req.app.get('io');

        for (const endpoint of honeypotPaths) {
            await ActivityLog.create({
                eventType: 'HONEYPOT_TRIGGERED',
                ipAddress: attackerIp,
                severity: 'critical',
                riskScore: 95,
                riskReasons: ['Accessed honeypot endpoint', 'Attacker reconnaissance'],
                metadata: {
                    endpoint,
                    method: 'GET',
                },
            });

            await SecurityEvent.create({
                type: 'HONEYPOT_ACCESS',
                ipAddress: attackerIp,
                description: `Honeypot endpoint accessed: ${endpoint}`,
                severity: 'critical',
                riskScore: 95,
                evidence: {
                    endpoint,
                    method: 'GET',
                },
            });

            socket?.emit('activity_log', {
                eventType: 'HONEYPOT_TRIGGERED',
                ipAddress: attackerIp,
                severity: 'critical',
                riskScore: 95,
                endpoint,
                metadata: { endpoint, method: 'GET' },
                timestamp: new Date(),
            });
        }

        socket?.emit('security_alert', {
            type: 'HONEYPOT_TRIGGERED',
            ipAddress: attackerIp,
            severity: 'critical',
            riskScore: 95,
            description: `Honeypot: ${honeypotPaths.length} suspicious endpoints accessed`,
            timestamp: new Date(),
        });

        return res.json({
            endpointsHit: honeypotPaths.length,
            riskScore: 95,
            level: 'critical',
            endpoints: honeypotPaths,
        });
    } catch (error) {
        console.error('Honeypot simulation error:', error);
        return res.status(500).json({ error: 'Failed to run honeypot simulation' });
    }
}

module.exports = {
    bruteForce,
    sqli,
    honeypot,
};